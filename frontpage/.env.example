# Web3Auth Client ID - get from https://dashboard.web3auth.io
# Required for on-chain features (Connect Wallet, Deposit to Contract)
VITE_WEB3AUTH_CLIENT_ID=YOUR_WEB3AUTH_CLIENT_ID

# Backend API URL — leave blank for local dev (proxy handles it)
# On Vercel, set this to your Backend Vercel deployment URL:
# VITE_API_BASE=https://corepayroll-api.vercel.app
VITE_API_BASE=

# Employee portal URL — on Vercel this is your Frontendemployee deployment
# VITE_EMPLOYEE_PORTAL_URL=https://corepayroll-employee.vercel.app
VITE_EMPLOYEE_PORTAL_URL=/employee

# HeLaChain
VITE_HELA_RPC_URL=https://testnet-rpc.helachain.com
VITE_HELA_CHAIN_ID=0xA2D18
VITE_HELA_EXPLORER_ADDRESS=https://testnet-explorer.helachain.com/address/
VITE_HELA_EXPLORER_TX=https://testnet-explorer.helachain.com/tx/
