# =============================================================
# CorePayroll Backend — Environment Variables
# =============================================================
# Copy this file to .env and fill in your values.
# On Vercel, set these in the Vercel project → Settings → Environment Variables.

# ---------------------------
# DATABASE (REQUIRED)
# ---------------------------
# Local MySQL:
# DATABASE_URL=mysql+pymysql://root:password@localhost:3306/payroll_db
#
# Hosted options (all have free tiers):
#   PlanetScale (MySQL):  DATABASE_URL=mysql+pymysql://user:pass@host/db?ssl_ca=/etc/ssl/certs/ca-certificates.crt
#   Neon (Postgres):      DATABASE_URL=postgresql+psycopg2://user:pass@host/db?sslmode=require
#   Supabase (Postgres):  DATABASE_URL=postgresql+psycopg2://postgres:pass@host:5432/postgres
DATABASE_URL=mysql+pymysql://root:1234@localhost:3306/payroll_db

# ---------------------------
# SECURITY (Set a strong random value in production!)
# ---------------------------
SECRET_KEY=CHANGE-ME-IN-PRODUCTION

# ---------------------------
# CORS (Vercel frontend URLs, comma-separated)
# ---------------------------
# Leave blank to allow all origins (for local dev).
# On Vercel, set to your frontend URLs:
# ALLOWED_ORIGINS=https://corepayroll.vercel.app,https://corepayroll-employee.vercel.app
ALLOWED_ORIGINS=

# ---------------------------
# BLOCKCHAIN / HeLaChain
# ---------------------------
HELA_RPC_URL=https://testnet-rpc.helachain.com
CONTRACT_ADDRESS=0xA4E4233714b7177860532Bc01B6D0182b81166EA
TAX_VAULT_ADDRESS=
TAX_RATE=10

# ---------------------------
# Smart contract deployer (only needed when deploying the contract)
# NEVER commit this to git!
# ---------------------------
# PRIVATE_KEY=0xYOUR_WALLET_PRIVATE_KEY
